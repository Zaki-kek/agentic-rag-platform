# Example environment for agentic-rag-platform.
# Copy to .env and override what you need: `cp .env.example .env`.
# Defaults below run the stack fully offline (no API keys, no database).

# Human-readable application name.
APP_NAME=agentic-rag-platform

# Logging verbosity: DEBUG | INFO | WARNING | ERROR | CRITICAL.
LOG_LEVEL=INFO

# LLM provider backend: echo | openai | anthropic | gigachat.
LLM_PROVIDER=echo

# Model name passed to the selected provider.
LLM_MODEL=gpt-4o-mini

# OpenAI API key (required when LLM_PROVIDER=openai or EMBEDDER=openai).
OPENAI_API_KEY=

# Anthropic API key (required when LLM_PROVIDER=anthropic).
ANTHROPIC_API_KEY=

# GigaChat credentials (required when LLM_PROVIDER=gigachat).
GIGACHAT_CREDENTIALS=

# Max concurrent in-flight requests to the LLM provider.
LLM_MAX_CONCURRENCY=8

# Per-call timeout (seconds) for a single LLM generate attempt; a slow call is
# cancelled and surfaced as an error instead of hanging.
LLM_TIMEOUT_SECONDS=60

# Embedding backend: hash | openai.
EMBEDDER=hash

# Embedding model name (used when EMBEDDER=openai).
EMBEDDING_MODEL=text-embedding-3-small

# Vector dimension for the deterministic hash embedder.
HASH_EMBEDDING_DIM=256

# Vector store backend: memory | pgvector.
VECTOR_STORE=memory

# Postgres DSN (used when VECTOR_STORE=pgvector).
DB_DSN=postgresql://postgres:postgres@db:5432/assistant

# asyncpg connection pool size (used when VECTOR_STORE=pgvector).
# DB_POOL_MIN connections are opened eagerly; the pool grows up to DB_POOL_MAX.
DB_POOL_MIN=1
DB_POOL_MAX=10

# Tracing backend: none | memory | langfuse.
TRACER=none

# Agent token budget for a single run (rough estimate: characters / 4 per LLM
# call, prompt plus reply). 0 = unlimited; the agent still stops at max_steps.
AGENT_MAX_TOKENS=0

# Character length of each document chunk.
CHUNK_SIZE=800

# Character overlap between adjacent chunks.
CHUNK_OVERLAP=120

# Number of chunks retrieved per query.
TOP_K=4

# Generation checkpoint store: memory | file.
# memory keeps job state process-local; file persists it as JSON so a restart
# resumes from the last completed stage. Default keeps the offline in-memory
# behavior.
CHECKPOINT_STORE=memory

# Directory for persisted checkpoints (used when CHECKPOINT_STORE=file).
CHECKPOINT_DIR=.checkpoints
